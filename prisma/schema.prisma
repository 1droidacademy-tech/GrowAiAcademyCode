generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  schemas  = ["growaiedu", "public"]
}

model User {
  id            String               @id @default(uuid())
  name          String
  email         String               @unique
  phone         String               @unique
  password_hash String
  role          Role                 @default(STUDENT)
  school_name   String?
  class_grade   String?
  created_at    DateTime             @default(now())
  enrollments   Enrollment[]
  reset_tokens  PasswordResetToken[]
  payments      Payment[]

  @@schema("growaiedu")
}

model Course {
  id             String       @id @default(uuid())
  title          String
  description    String
  price          Float
  level          String
  duration       String
  status         String       @default("ACTIVE")
  created_at     DateTime     @default(now())
  early_discount Float        @default(0)
  enrollments    Enrollment[]
  payments       Payment[]

  @@schema("growaiedu")
}

model PromoCode {
  id         String   @id @default(uuid())
  code       String   @unique
  discount   Float
  is_active  Boolean  @default(true)
  created_at DateTime @default(now())

  @@schema("growaiedu")
}

model Enrollment {
  id             String   @id @default(uuid())
  user_id        String
  course_id      String
  payment_status String
  payment_id     String?
  enrolled_at    DateTime @default(now())
  course         Course   @relation(fields: [course_id], references: [id])
  user           User     @relation(fields: [user_id], references: [id])

  @@unique([user_id, course_id])
  @@schema("growaiedu")
}

model Payment {
  id                  String   @id @default(uuid())
  user_id             String
  course_id           String
  amount              Float
  payment_gateway     String   @default("razorpay")
  razorpay_order_id   String?
  razorpay_payment_id String?
  razorpay_signature  String?
  status              String
  created_at          DateTime @default(now())
  course              Course   @relation(fields: [course_id], references: [id])
  user                User     @relation(fields: [user_id], references: [id])

  @@schema("growaiedu")
}

model ContactMessage {
  id         String   @id @default(uuid())
  name       String
  email      String
  phone      String
  message    String
  created_at DateTime @default(now())

  @@schema("growaiedu")
}

model PasswordResetToken {
  id         String   @id @default(uuid())
  token      String   @unique
  user_id    String
  expires_at DateTime
  created_at DateTime @default(now())
  user       User     @relation(fields: [user_id], references: [id])

  @@schema("growaiedu")
}

enum Role {
  STUDENT
  ADMIN

  @@schema("growaiedu")
}
